# DeepSeek LLM settings. DeepSeek exposes an OpenAI-compatible API.
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_api_key_here
LLM_MODEL=deepseek-chat

# Tavily web fallback settings.
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key_here

# Optional Langfuse observability export.
# SQLite remains the source of truth; Langfuse is only a dashboard sink.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
LANGFUSE_ENVIRONMENT=production
LANGFUSE_RELEASE=prototype
LANGFUSE_SAMPLE_RATE=1.0

# Runtime server settings.
HOST=0.0.0.0
PORT=8000
DB_PATH=/data/venture_metrics.db
